# 이 파일을 복사해서 .env 로 만들고 실제 값을 채우세요. (.env 는 깃에 올리지 마세요)

# AI 풀이 생성용 Anthropic API 키 (필수: AI 풀이를 쓰려면)
# 발급: https://console.anthropic.com  →  Settings → API Keys
ANTHROPIC_API_KEY=

# 사용할 모델 (선택, 기본값 claude-sonnet-4-6)
#   claude-haiku-4-5  = 더 빠르고 저렴
#   claude-opus-4-8   = 최고 품질(비쌈)
AI_MODEL=claude-sonnet-4-6

# 배포한 실제 도메인
NEXT_PUBLIC_SITE_URL=https://your-domain.com
